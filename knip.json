{
  "$schema": "./node_modules/knip/schema.json",

  "paths": {
    "@/*": ["./src/*"]
  },

  "entry": ["src/sentry.client.config.ts"],

  "project": ["src/**/*.{ts,tsx,astro}"],

  "vitest": {
