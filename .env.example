PORTLESS_HTTPS=1
PORTLESS_PORT=1355
PORTLESS_SYNC_HOSTS=1

# Ollama API endpoint — use http://localhost:11434 for native Ollama, http://ollama:11434 inside Docker Compose.
# This value is used both server-side (API routes) and client-side (settings UI default).
# When the user configures a different URL in the web UI, that value takes priority in every request.
PUBLIC_OLLAMA_BASE_URL=http://localhost:11434

# Astro server bind address (use 0.0.0.0 in Docker)
HOST=0.0.0.0

# Astro server port
PORT=4321

# Logging level for server Pino logger (debug, info, warn, error)
LOG_LEVEL=info

# ── Sentry (Error Tracking) ───────────────────────────────────────────────────

# Browser-side Sentry DSN
PUBLIC_SENTRY_DSN=

# Browser trace sampling rate (0-1, 0 = disabled)
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Minimum log level forwarded to Sentry in browser (debug, info, warn, error)
PUBLIC_SENTRY_LOG_LEVEL=warn

# Browser console log level (debug, info, warn, error)
PUBLIC_LOG_LEVEL=info

# Sentry Auth Token for CLI uploads
SENTRY_AUTH_TOKEN=

# ── Axiom (Cloud Logging) ─────────────────────────────────────────────────────

# Axiom API token (from axiom.co → Settings → API Tokens)
AXIOM_TOKEN=

# Axiom dataset to ingest logs into
AXIOM_DATASET=slm-router

# Minimum log level forwarded to Axiom on server (debug, info, warn, error)
AXIOM_LOG_LEVEL=info

# The public URL of the site
PUBLIC_SITE_URL=https://cubepath.localhost:1355
