# Ollama API endpoint — use http://localhost:11434 for native Ollama, http://ollama:11434 inside Docker Compose
OLLAMA_BASE_URL=http://localhost:11434

# Model for Explain task
OLLAMA_EXPLAIN_MODEL=phi3.5

# Model for Generate Tests task
OLLAMA_TEST_MODEL=qwen2.5-coder:7b

# Model for Refactor task
OLLAMA_REFACTOR_MODEL=qwen2.5-coder:7b

# Model for Write Commit task
OLLAMA_COMMIT_MODEL=qwen2.5-coder:7b

# Model for Translation (dedicated translation SLM, default: icky/translate)
OLLAMA_TRANSLATE_MODEL=icky/translate

# Analyst model for routing intelligence (small model, default: llama3.2:1b)
OLLAMA_ANALYST_MODEL=llama3.2:1b

# Astro server bind address (use 0.0.0.0 in Docker)
HOST=0.0.0.0

# Astro server port
PORT=4321
