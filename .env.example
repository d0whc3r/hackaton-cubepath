# Ollama API endpoint — use http://localhost:11434 for native Ollama, http://ollama:11434 inside Docker Compose
OLLAMA_BASE_URL=http://localhost:11434

# Analyst model for routing intelligence (runs on every request, keep it small and fast)
OLLAMA_ANALYST_MODEL=qwen2.5:0.5b

# Analysis tasks
OLLAMA_EXPLAIN_MODEL=qwen3:4b
OLLAMA_ERROR_EXPLAIN_MODEL=qwen3:4b
OLLAMA_PERFORMANCE_HINT_MODEL=granite-code:8b
OLLAMA_DEAD_CODE_MODEL=granite-code:8b
OLLAMA_NAMING_HELPER_MODEL=qwen3:4b

# Generation tasks
OLLAMA_TEST_MODEL=qwen2.5-coder:7b
OLLAMA_REFACTOR_MODEL=granite-code:8b
OLLAMA_COMMIT_MODEL=qwen2.5-coder:1.5b
OLLAMA_DOCSTRING_MODEL=qwen2.5-coder:3b
OLLAMA_TYPE_HINTS_MODEL=qwen2.5-coder:7b

# Language tasks
OLLAMA_TRANSLATE_MODEL=translategemma:4b

# Astro server bind address (use 0.0.0.0 in Docker)
HOST=0.0.0.0

# Astro server port
PORT=4321

# Logging level for server Pino logger (debug, info, warn, error)
LOG_LEVEL=info


# Optional Sentry DSN for server-side error reporting
SENTRY_DSN=

# Optional Sentry tracing sample rate on server (0-1)
SENTRY_TRACES_SAMPLE_RATE=0

# Optional minimum log level for Sentry server transport
SENTRY_LOG_LEVEL=warn

# Public logging level for browser logger
PUBLIC_LOG_LEVEL=info

# Minimum browser log level to forward to /api/telemetry/log (warn by default)
PUBLIC_LOG_FORWARD_LEVEL=warn

# Optional HTTP endpoint for browser LogLayer HTTP transport
PUBLIC_LOG_HTTP_ENDPOINT=/api/telemetry/log

# Optional Sentry DSN for browser-side error reporting
PUBLIC_SENTRY_DSN=

# Optional Sentry tracing sample rate on browser (0-1)
PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Optional minimum log level for Sentry browser transport
PUBLIC_SENTRY_LOG_LEVEL=warn


# ── Grafana Cloud — OpenTelemetry (OTLP) ──────────────────────────────────────
# Logs → Loki · Metrics → Mimir · Traces → Tempo
#
# How to get these values:
#   1. Log in to grafana.com → your stack
#   2. Connections → Add new connection → OpenTelemetry
#   3. Copy the Instance ID and generate a Cloud Access Policy token
#      (required scopes: logs:write, metrics:write, traces:write)
GRAFANA_INSTANCE_ID=
GRAFANA_CLOUD_TOKEN=
# Default region is prod-us-west-0 — change to match your stack region
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-west-0.grafana.net/otlp

# ── Grafana Cloud — Faro (Frontend / RUM) ────────────────────────────────────
# Captures: JS errors · Web Vitals · fetch timings · console logs · sessions
#
# How to get this URL:
#   1. Grafana Cloud → Frontend Observability → Create App
#   2. Name it "cubepath" and copy the Web URL
#   Format: https://faro-collector-prod-us-west-0.grafana.net/collect/{api-key}
PUBLIC_GRAFANA_FARO_URL=
