---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  fullScreen?: boolean;
}

const APP_NAME = 'SLM Router';
const DEFAULT_TITLE = 'Intelligent Code Assistant';

const {
  title = DEFAULT_TITLE,
  description = 'Intelligent small-model routing for developer workflows. Route code tasks to specialist AI models running locally with Ollama.',
  fullScreen = true,
} = Astro.props;

const pageTitle = title.startsWith(`${APP_NAME};`) ? title : `${APP_NAME}; ${title}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://slm-router.local');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Primary -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6366f1" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#818cf8" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="SLM Router" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <ClientRouter />
    <!-- Apply theme before first paint and re-apply after every SPA navigation -->
    <script is:inline>
      (function () {
        function readStoredTheme() {
          const raw = localStorage.getItem('theme');
          if (raw === 'dark' || raw === 'light') {
            return raw;
          }
          if (raw === null) {
            return null;
          }
          try {
            const parsed = JSON.parse(raw);
            return parsed === 'dark' || parsed === 'light' ? parsed : null;
          } catch {
            return null;
          }
        }

        function applyTheme() {
          const stored = readStoredTheme();
          const prefersDark = globalThis.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', stored ? stored === 'dark' : prefersDark);
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body class:list={[fullScreen ? 'h-screen overflow-hidden' : 'min-h-screen', 'bg-background text-foreground']}>
    <slot />
  </body>
</html>
