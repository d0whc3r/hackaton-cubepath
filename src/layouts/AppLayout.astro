---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  fullScreen?: boolean;
}

const {
  title,
  description = 'Intelligent small-model routing for developer workflows. Route code tasks to specialist AI models running locally with Ollama.',
  fullScreen = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://slm-router.local');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6366f1" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#818cf8" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="SLM Router" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <ClientRouter />
    <!-- Apply theme before first paint and re-apply after every SPA navigation -->
    <script is:inline>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem('theme');
          const prefersDark = globalThis.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', stored === 'dark' || (!stored && prefersDark));
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body class:list={[fullScreen ? 'h-screen overflow-hidden' : 'min-h-screen', 'bg-background text-foreground']}>
    <slot />
  </body>
</html>
