---
import OverviewHero from '@/components/layout/OverviewHero.astro'
import { OllamaStatusBadge } from '@/components/layout/OllamaStatusBadge'
import { OverviewTaskCards } from '@/components/layout/OverviewTaskCards'
import NonTaskLayout from '@/layouts/NonTaskLayout.astro'

const statItems = [
  { label: 'Specialist tasks', sub: 'analysis + generation', value: '10' },
  { label: 'Cloud API cost', sub: 'local inference via Ollama', value: '$0' },
  { label: 'Data residency', sub: 'requests stay local by default', value: 'Local' },
  { label: 'Routing approach', sub: 'analyst classification + specialist execution', value: 'Task-scoped' },
]

const slmAdvantages = [
  'Task-scoped prompts reduce noise from unrelated instructions.',
  'Smaller local models provide faster iteration for coding loops.',
  'Per-task model mapping lets you optimize quality vs speed explicitly.',
  'No cloud lock-in for core workflows and predictable operating cost.',
]

const genericLlmTradeoffs = [
  'Single generalist model handles every task with less specialization.',
  'Higher prompt/context overhead for routine developer operations.',
  'Cost grows with usage and larger context windows.',
  'Less transparent routing logic and weaker per-task control.',
]

const platformPillars = [
  {
    badge: 'Routing Intelligence',
    desc: 'Analyst pre-analysis detects language, intent, diff context, and framework signals before model routing.',
    title: 'Control Plane',
  },
  {
    badge: 'Task Specialists',
    desc: 'Each task runs on a dedicated specialist model profile with streaming responses and token-aware continuation.',
    title: 'Execution Plane',
  },
  {
    badge: 'Operator UX',
    desc: 'Per-task conversation history, live progress visibility, optional translation, and instant cost comparisons.',
    title: 'Experience Plane',
  },
]

const workflowSteps = [
  {
    desc: 'Paste code, error traces, diffs, or attach files. The request is normalized into a structured payload.',
    step: '01',
    title: 'Input + context',
  },
  {
    desc: 'A lightweight Analyst infers language and workload traits to reduce misrouting and improve output quality.',
    step: '02',
    title: 'Analyst classification',
  },
  {
    desc: 'The selected specialist model handles only its domain task, instead of using a generic one-size model.',
    step: '03',
    title: 'Specialist execution',
  },
  {
    desc: 'Responses stream in real time and can auto-continue for long outputs so sessions do not truncate mid-answer.',
    step: '04',
    title: 'Streaming + continuation',
  },
  {
    desc: 'Optionally translate prose output and inspect local-vs-cloud cost estimates for each interaction.',
    step: '05',
    title: 'Post-processing',
  },
]

---

<NonTaskLayout title="Intelligent Code Assistant">
  <OverviewHero />

  <section class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    {
      statItems.map((item) => (
        <article class="rounded-xl border border-border/70 bg-card p-5 shadow-sm">
          <p class="text-[11px] font-semibold tracking-[0.2em] text-muted-foreground uppercase">{item.label}</p>
          <p class="mt-4 text-4xl font-bold tracking-tight text-foreground">{item.value}</p>
          <p class="mt-2 text-sm text-muted-foreground">{item.sub}</p>
        </article>
      ))
    }
  </section>

  <section id="approach" class="mt-14 scroll-mt-24">
    <div class="mb-5">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground">Why this SLM approach works</h2>
      <p class="text-sm text-muted-foreground">
        For developer workflows in this app, routing to smaller specialist models gives better control, lower cost, and
        faster turnaround than sending every request to one large generalist model.
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      <article class="rounded-xl border border-border/70 bg-card p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-foreground">SLM Router benefits</h3>
        <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
          {slmAdvantages.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="rounded-xl border border-border/70 bg-card p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-foreground">Generic LLM tradeoffs</h3>
        <ul class="mt-4 space-y-2 text-sm text-muted-foreground">
          {genericLlmTradeoffs.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section id="platform" class="mt-14 scroll-mt-24">
    <div class="mb-5">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground">Platform architecture</h2>
      <p class="text-sm text-muted-foreground">
        Structured into three planes so routing, execution, and UX evolve independently.
      </p>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {
        platformPillars.map((pillar) => (
          <article class="rounded-xl border border-border/70 bg-card p-6 shadow-sm">
            <p class="mb-2 text-xs font-medium text-muted-foreground">{pillar.badge}</p>
            <h3 class="mb-2 text-lg font-semibold text-foreground">{pillar.title}</h3>
            <p class="text-sm leading-7 text-muted-foreground">{pillar.desc}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="workflow" class="mt-14 scroll-mt-24">
    <div class="mb-4">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground">Operational workflow</h2>
      <p class="text-sm text-muted-foreground">
        End-to-end lifecycle for each request, from raw input to final enriched output.
      </p>
    </div>
    <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-5">
      {
        workflowSteps.map((item) => (
          <article class="rounded-xl border border-border/70 bg-card p-4 shadow-sm">
            <p class="mb-2 font-mono text-xs text-muted-foreground">{item.step}</p>
            <h3 class="mb-2 text-sm font-semibold text-foreground">{item.title}</h3>
            <p class="text-xs leading-6 text-muted-foreground">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="tasks" class="mt-14 scroll-mt-24">
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-foreground">Task catalog</h2>
        <p class="text-sm text-muted-foreground">Live model labels reflect your current local configuration.</p>
      </div>
      <div class="flex items-center gap-3">
        <OllamaStatusBadge client:load />
        <a href="/settings" class="text-sm font-medium text-primary hover:underline">Adjust model assignments</a>
      </div>
    </div>
    <OverviewTaskCards client:load />
  </section>
</NonTaskLayout>
