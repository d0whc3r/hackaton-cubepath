---
import { OverviewTaskCards } from '@/components/layout/OverviewTaskCards'
import NonTaskLayout from '@/layouts/NonTaskLayout.astro'

const statItems = [
  { label: 'Specialist tasks', sub: 'analysis + generation', value: '10' },
  { label: 'Analyst model', sub: 'pre-routing intelligence layer', value: '1' },
  { label: 'Translation targets', sub: 'code blocks preserved as-is', value: '20+' },
  { label: 'Cloud API cost', sub: 'local inference via Ollama', value: '$0' },
]

const platformPillars = [
  {
    badge: 'Routing Intelligence',
    desc: 'Analyst pre-analysis detects language, intent, diff context, and framework signals before model routing.',
    title: 'Control Plane',
  },
  {
    badge: 'Task Specialists',
    desc: 'Each task runs on a dedicated specialist model profile with streaming responses and token-aware continuation.',
    title: 'Execution Plane',
  },
  {
    badge: 'Operator UX',
    desc: 'Per-task conversation history, live progress visibility, optional translation, and instant cost comparisons.',
    title: 'Experience Plane',
  },
]

const workflowSteps = [
  {
    desc: 'Paste code, error traces, diffs, or attach files. The request is normalized into a structured payload.',
    step: '01',
    title: 'Input + context',
  },
  {
    desc: 'A lightweight Analyst infers language and workload traits to reduce misrouting and improve output quality.',
    step: '02',
    title: 'Analyst classification',
  },
  {
    desc: 'The selected specialist model handles only its domain task, instead of using a generic one-size model.',
    step: '03',
    title: 'Specialist execution',
  },
  {
    desc: 'Responses stream in real time and can auto-continue for long outputs so sessions do not truncate mid-answer.',
    step: '04',
    title: 'Streaming + continuation',
  },
  {
    desc: 'Optionally translate prose output and inspect local-vs-cloud cost estimates for each interaction.',
    step: '05',
    title: 'Post-processing',
  },
]
---

<NonTaskLayout title="Intelligent Code Assistant">
  <section class="relative isolate overflow-hidden rounded-2xl border border-border/70 bg-card p-6 md:p-10">
    <div class="pointer-events-none absolute inset-0 opacity-70">
      <div class="absolute -top-20 -right-16 h-64 w-64 rounded-full bg-primary/15 blur-3xl"></div>
      <div class="absolute -bottom-28 -left-12 h-64 w-64 rounded-full bg-blue-500/10 blur-3xl"></div>
    </div>

    <div class="relative grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div>
        <p
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
          Local-first coding copilot with task-specialist routing
        </p>
        <h1 class="max-w-3xl text-3xl font-bold tracking-tight text-foreground sm:text-5xl">
          One router.
          <span class="bg-linear-to-r from-primary to-blue-500 bg-clip-text text-transparent">
            Ten specialist workflows.</span
          >
        </h1>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base">
          SLM Router now covers a full coding assistance surface: explain, error triage, testing, refactor, naming,
          dead code detection, docstrings, type hints, commit drafting, and performance advisory. Every request stays
          local and is routed through an Analyst before specialist execution.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/tasks/explain"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-opacity hover:opacity-90"
          >
            Open Task Workspace
          </a>
          <a
            href="#tasks"
            class="inline-flex items-center gap-2 rounded-lg border border-border bg-background px-5 py-2.5 text-sm font-medium text-foreground transition-colors hover:bg-muted"
          >
            Browse Task Catalog
          </a>
        </div>
      </div>

      <div class="rounded-xl border border-border/70 bg-background/80 p-4">
        <p class="mb-3 text-xs font-semibold tracking-wide text-muted-foreground uppercase">Current scope</p>
        <div class="grid grid-cols-2 gap-2 text-xs">
          <div class="rounded-md border border-border/60 bg-card px-3 py-2">
            <p class="font-semibold text-foreground">Analysis</p>
            <p class="text-muted-foreground">Explain · Error · Perf · Dead Code · Naming</p>
          </div>
          <div class="rounded-md border border-border/60 bg-card px-3 py-2">
            <p class="font-semibold text-foreground">Generation</p>
            <p class="text-muted-foreground">Tests · Refactor · Commit · Docs · Types</p>
          </div>
        </div>
        <p class="mt-3 text-xs leading-relaxed text-muted-foreground">
          Configurable model mapping per task, plus dedicated Analyst and translator models in Settings.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {
      statItems.map((item) => (
        <article class="rounded-xl border border-border/70 bg-card p-4 shadow-sm">
          <p class="text-2xl font-bold text-primary">{item.value}</p>
          <p class="mt-0.5 text-xs font-medium text-foreground">{item.label}</p>
          <p class="text-xs text-muted-foreground">{item.sub}</p>
        </article>
      ))
    }
  </section>

  <section id="platform" class="mt-14 scroll-mt-24">
    <div class="mb-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">Platform architecture</h2>
      <p class="text-sm text-muted-foreground">
        Structured into three planes so routing, execution, and UX evolve independently.
      </p>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {
        platformPillars.map((pillar) => (
          <article class="rounded-xl border border-border/70 bg-card p-5 shadow-sm">
            <p class="mb-2 inline-flex rounded-full bg-primary/10 px-2 py-0.5 text-[11px] font-medium text-primary">
              {pillar.badge}
            </p>
            <h3 class="mb-1.5 font-semibold text-foreground">{pillar.title}</h3>
            <p class="text-sm leading-relaxed text-muted-foreground">{pillar.desc}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="workflow" class="mt-14 scroll-mt-24">
    <div class="mb-4">
      <h2 class="text-xl font-semibold tracking-tight text-foreground">Operational workflow</h2>
      <p class="text-sm text-muted-foreground">
        End-to-end lifecycle for each request, from raw input to final enriched output.
      </p>
    </div>
    <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-5">
      {
        workflowSteps.map((item) => (
          <article class="rounded-xl border border-border/70 bg-card p-4 shadow-sm">
            <p class="mb-2 font-mono text-xs text-primary">{item.step}</p>
            <h3 class="mb-1 text-sm font-semibold text-foreground">{item.title}</h3>
            <p class="text-xs leading-relaxed text-muted-foreground">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="tasks" class="mt-14 scroll-mt-24">
    <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-xl font-semibold tracking-tight text-foreground">Task catalog</h2>
        <p class="text-sm text-muted-foreground">Live model labels reflect your current local configuration.</p>
      </div>
      <a href="/settings" class="text-sm font-medium text-primary hover:underline">Adjust model assignments</a>
    </div>
    <OverviewTaskCards client:load />
  </section>
</NonTaskLayout>
