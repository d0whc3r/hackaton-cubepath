---
import { ErrorScreen } from '@/components/layout/ErrorScreen'
import NonTaskLayout from '@/layouts/NonTaskLayout.astro'
---

<NonTaskLayout title="Unexpected server error">
  <ErrorScreen
    code="500"
    title="Unexpected error in request processing"
    description="The server could not complete this operation. Your current local model configuration is still safe."
    hint="Retry the last action or check model availability in settings before running the request again."
    actions={[
      { href: '/', label: 'Back to overview', variant: 'outline', icon: 'home' },
      { href: '/settings', label: 'Check model status', variant: 'default', icon: 'settings' },
      { href: '/tasks/explain', label: 'Retry in tasks', variant: 'secondary', icon: 'retry' },
    ]}
  />
</NonTaskLayout>
