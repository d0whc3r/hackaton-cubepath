---
import { TaskApp } from '@/components/chat/TaskApp'
import { taskPageBySlug, taskPages } from '@/data/task-pages'
import TaskPageLayout from '@/layouts/TaskPageLayout.astro'

export function getStaticPaths() {
  return taskPages.map((taskPage) => ({
    params: { task: taskPage.slug },
  }))
}

const { task } = Astro.params
const config = task ? taskPageBySlug[task] : undefined

if (!config) {
  return Astro.redirect('/')
}
---

<TaskPageLayout title={config.title} description={config.description}>
  <TaskApp
    client:load
    fixedTaskType={config.fixedTaskType}
    pageTitle={config.pageTitle}
    pageDescription={config.pageDescription}
  />
</TaskPageLayout>
