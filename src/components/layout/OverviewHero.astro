---
import { OllamaStatusBadge } from '@/components/layout/OllamaStatusBadge'

const signalItems = [
  'Use your own localhost Ollama per user',
  'Analyst-first classification',
  'Streaming with continuation',
  'Per-task model mapping',
]
---

<section class="relative overflow-hidden rounded-2xl border border-border/70 bg-card px-6 py-8 shadow-sm md:px-10 md:py-10">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-linear-to-b from-muted/50 to-transparent"></div>

  <div class="relative grid gap-8 xl:grid-cols-[1.15fr_0.85fr] xl:items-start">
    <div class="max-w-3xl">
      <div class="mb-4">
        <OllamaStatusBadge client:only="react" />
      </div>

      <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-foreground sm:text-5xl xl:text-6xl">
        Route every coding request through a
        <span class="text-primary"> specialist local model stack.</span>
      </h1>
      <p class="mt-5 max-w-2xl text-sm leading-7 text-muted-foreground md:text-base">
        SLM Router turns a single chat surface into a controlled multi-workflow system: Analyst classification,
        task-specialist execution, live streaming, optional translation, and local cost discipline without cloud
        dependencies. The result is a developer loop optimized for speed, privacy, and per-task precision.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/tasks/explain"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-90"
        >
          Open Task Workspace
        </a>
        <a
          href="#tasks"
          class="inline-flex items-center gap-2 rounded-lg border border-border/80 bg-background px-5 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-muted"
        >
          Browse Task Catalog
        </a>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        {
          signalItems.map((item, index) => (
            <div class="flex items-center gap-3 rounded-lg border border-border/60 bg-background px-4 py-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-border text-xs font-semibold text-foreground">
                0{index + 1}
              </span>
              <span class="text-sm font-medium text-foreground">{item}</span>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="rounded-xl border border-border/70 bg-background/50 p-5">
      <div class="space-y-4">
        <div>
          <p class="text-[11px] font-semibold tracking-[0.18em] text-muted-foreground uppercase">Current scope</p>
          <p class="mt-1 text-lg font-semibold text-foreground">Analysis and generation planes</p>
        </div>
        <div class="space-y-1.5 text-sm text-foreground">
          <p>Analysis: Explain, Error, Performance, Dead Code, Naming</p>
          <p>Generation: Tests, Refactor, Commit, Docstrings, Type Hints</p>
        </div>
        <div class="border-t border-border pt-4">
          <p class="text-[11px] font-semibold tracking-[0.18em] text-muted-foreground uppercase">Routing flow</p>
          <ol class="mt-2 space-y-2 text-sm text-muted-foreground">
            <li>1. Input normalized (code, diff, errors, prompt)</li>
            <li>2. Analyst infers intent and workload traits</li>
            <li>3. Specialist executes with streaming</li>
          </ol>
        </div>
        <div class="border-t border-border pt-4">
          <p class="text-[11px] font-semibold tracking-[0.18em] text-muted-foreground uppercase">Config</p>
          <p class="mt-2 text-sm text-muted-foreground">
            Each user can point to their own local Ollama at localhost, or use a server-provided Ollama endpoint (which
            may have shared-resource limitations).
          </p>
        </div>
      </div>
    </aside>
  </div>
</section>
