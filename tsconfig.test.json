{
  "extends": ["astro/tsconfigs/strict", "./tsconfig.base.json"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "vitest.config.ts",
    "src/test/**/*",
    "src/__tests__/**/*"
  ],
  "exclude": ["dist"]
}
