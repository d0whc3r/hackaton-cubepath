{
  "name": "hackaton-cubepath",
  "version": "1.0.0",
  "private": true,
  "description": "Astro SSR project configured for Cloudflare Workers and Dockploy compatibility",
  "keywords": [
    "astro",
    "cloudflare-workers",
    "dockploy"
  ],
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview --host 0.0.0.0 --port 8787",
    "build": "astro check && astro build",
    "type-check": "astro check",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --no-error-on-unmatched-pattern --write \"src/**/*.{js,mjs,cjs,jsx,ts,tsx}\" package.json tsconfig.json wrangler.jsonc astro.config.ts",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check \"src/**/*.{js,mjs,cjs,jsx,ts,tsx}\" package.json tsconfig.json wrangler.jsonc astro.config.ts",
    "preview": "astro preview --host 0.0.0.0 --port 8787",
    "generate-types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy",
    "prepare": "husky",
    "pre-commit": "lint-staged --allow-empty",
    "format:fix": "pnpm run lint:fix && pnpm run format"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^6.0.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/node": "^10.0.3",
    "@astrojs/react": "^5.0.1",
    "@astrojs/ts-plugin": "^1.10.7",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern --write"
    ],
    "*.{json,jsonc,yml,yaml}": [
      "oxfmt --no-error-on-unmatched-pattern --write"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1"
}
