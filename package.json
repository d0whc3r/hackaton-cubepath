{
  "name": "hackaton-cubepath",
  "version": "1.0.0",
  "private": true,
  "description": "Intelligent SLM Router for developer tasks with task-aware routing, live SSE output, and local Ollama models.",
  "keywords": [
    "astro",
    "developer-tools",
    "llm-routing",
    "ollama",
    "react",
    "shadcn-ui",
    "slm",
    "typescript"
  ],
  "homepage": "https://github.com/d0whc3r/hackaton-cubepath#readme",
  "bugs": {
    "url": "https://github.com/d0whc3r/hackaton-cubepath/issues"
  },
  "license": "MIT",
  "author": "d0whc3r",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d0whc3r/hackaton-cubepath.git"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview --host 0.0.0.0 --port 8787",
    "build": "astro check && astro build",
    "type-check": "astro check",
    "lint": "oxlint",
    "lint:fix": "pnpm lint --fix --fix-suggestions",
    "format": "oxfmt --no-error-on-unmatched-pattern --write",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check",
    "preview": "astro preview --host 0.0.0.0 --port 8787",
    "generate-types": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy",
    "prepare": "husky",
    "pre-commit": "lint-staged --allow-empty",
    "format:fix": "pnpm run lint:fix && pnpm run format",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.47",
    "@fontsource-variable/inter": "5.2.8",
    "@tanstack/react-query": "5.94.5",
    "ai": "6.0.134",
    "astro": "6.0.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "shadcn": "4.1.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "wretch": "3.0.7",
    "wretch-middlewares": "0.1.13",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/cloudflare": "13.1.3",
    "@astrojs/node": "10.0.3",
    "@astrojs/react": "5.0.1",
    "@astrojs/ts-plugin": "1.10.7",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query-devtools": "5.94.5",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "20.8.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "msw": "2.12.14",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0",
    "wrangler": "4.76.0"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern --write"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1"
}
