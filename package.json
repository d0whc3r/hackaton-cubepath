{
  "name": "hackaton-cubepath",
  "version": "1.0.0",
  "private": true,
  "description": "Intelligent SLM Router for developer tasks with task-aware routing, live SSE output, and local Ollama models.",
  "keywords": [
    "astro",
    "developer-tools",
    "llm-routing",
    "ollama",
    "react",
    "shadcn-ui",
    "slm",
    "typescript"
  ],
  "homepage": "https://github.com/d0whc3r/hackaton-cubepath#readme",
  "bugs": {
    "url": "https://github.com/d0whc3r/hackaton-cubepath/issues"
  },
  "license": "MIT",
  "author": "d0whc3r",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d0whc3r/hackaton-cubepath.git"
  },
  "type": "module",
  "scripts": {
    "dev": "portless cubepath astro dev",
    "start": "pnpm run build && portless cubepath astro preview --host 0.0.0.0 --port 8787",
    "build": "astro check && astro build",
    "type-check": "astro check && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "oxlint",
    "lint:fix": "pnpm lint --fix --fix-suggestions",
    "format": "oxfmt --no-error-on-unmatched-pattern --write",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check",
    "prepare": "husky",
    "pre-commit": "lint-staged --allow-empty",
    "format:fix": "pnpm run lint:fix && pnpm run format",
    "test": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.48",
    "@fontsource-variable/inter": "5.2.8",
    "@loglayer/transport-sentry": "2.0.2",
    "@sentry/astro": "10.46.0",
    "@sentry/browser": "10.46.0",
    "@tanstack/react-query": "5.95.2",
    "ai": "6.0.141",
    "astro": "6.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "loglayer": "9.1.0",
    "lucide-react": "1.7.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "serialize-error": "13.0.1",
    "shadcn": "4.1.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "wretch": "3.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/react": "5.0.2",
    "@astrojs/ts-plugin": "1.10.7",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query-devtools": "5.95.2",
    "@testing-library/react": "16.3.2",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "knip": "6.1.0",
    "lint-staged": "16.4.0",
    "msw": "2.12.14",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "portless": "0.7.2",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern --write"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
