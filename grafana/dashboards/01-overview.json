{
  "__inputs": [
    { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" },
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_TEMPO", "label": "Tempo", "type": "datasource", "pluginId": "tempo" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Cubepath — Vista general: requests, errores, latencia y estado del sistema",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "API Requests",
      "url": "/d/cubepath-api",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Streaming AI",
      "url": "/d/cubepath-streaming",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Security",
      "url": "/d/cubepath-security",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Frontend RUM",
      "url": "/d/cubepath-faro",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "HTTP Clients",
      "url": "/d/cubepath-http",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Resumen del servicio",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests (24h)",
      "description": "Número total de requests al endpoint /api/route en las últimas 24 horas",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(cubepath_route_requests_total[24h])",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests Bloqueados (24h)",
      "description": "Requests rechazados por el railguard de seguridad",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(cubepath_route_blocked_total[24h])",
          "legendFormat": "Bloqueados",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tasa de Bloqueo",
      "description": "Porcentaje de requests bloqueados sobre el total",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * rate(cubepath_route_blocked_total[1h]) / (rate(cubepath_route_requests_total[1h]) + rate(cubepath_route_blocked_total[1h]))",
          "legendFormat": "% Bloqueados",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Latencia Mediana Streaming",
      "description": "P50 de duración de respuestas en streaming",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 15000 }
            ]
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(cubepath_stream_duration_milliseconds_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Latencia P95 Streaming",
      "description": "P95 de duración de respuestas en streaming",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 30000 }
            ]
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(cubepath_stream_duration_milliseconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Errores de log (1h)",
      "description": "Número de entradas de log con nivel ERROR en la última hora",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service_name=\"cubepath\", level=\"error\"}[1h]))",
          "legendFormat": "Errores",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Tráfico y Latencia",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate por Tipo de Tarea",
      "description": "Tasa de requests al minuto, desglosada por task.type",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(cubepath_route_requests_total[5m])",
          "legendFormat": "{{task_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Latencia Streaming (percentiles)",
      "description": "P50, P90 y P99 de la duración de las respuestas en streaming",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(cubepath_stream_duration_milliseconds_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.90, rate(cubepath_stream_duration_milliseconds_bucket[5m]))",
          "legendFormat": "P90",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(cubepath_stream_duration_milliseconds_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Logs recientes",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Últimos logs del servicio cubepath",
      "description": "Stream en vivo de todos los logs estructurados emitidos por el servicio",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=\"cubepath\"} | json",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Trazas recientes",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "traces",
      "title": "Trazas — cubepath",
      "description": "Trazas distribuidas del servicio cubepath enviadas a Tempo",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 10 },
      "options": {},
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "queryType": "search",
          "serviceName": "cubepath",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["cubepath", "overview"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values({service_name=\"cubepath\"}, deployment_environment)",
        "current": {},
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Cubepath — Overview",
  "uid": "cubepath-overview",
  "version": 1
}
