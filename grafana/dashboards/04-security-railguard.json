{
  "__inputs": [
    { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" },
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "name": "Bloqueos",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "{service_name=\"cubepath\"} | json | message = \"route.blocked_by_railguard\"",
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "step": "60s",
        "titleFormat": "BLOCKED: {{blockReason}}",
        "textFormat": "task: {{taskType}}"
      }
    ]
  },
  "description": "Cubepath — Seguridad y Railguard: bloqueos, razones, patrones de abuso y logs de validación",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "KPIs de Seguridad",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Bloqueos totales (24h)",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(cubepath_route_blocked_total[24h])",
          "legendFormat": "Bloqueados",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tasa de bloqueo (%)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * rate(cubepath_route_blocked_total[1h]) / (rate(cubepath_route_requests_total[1h]) + rate(cubepath_route_blocked_total[1h]))",
          "legendFormat": "% Bloqueados",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errores de validación Zod (1h)",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service_name=\"cubepath\"} | json | message = \"route.validation_error\" [1h]))",
          "legendFormat": "Validation errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "JSON inválido (1h)",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({service_name=\"cubepath\"} | json | message = \"route.invalid_json\" [1h]))",
          "legendFormat": "Invalid JSON",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Bloqueos a lo largo del tiempo",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Tasa de bloqueos — Railguard",
      "description": "Número de requests bloqueados por minuto, por tipo de tarea (task.type).",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(cubepath_route_blocked_total[5m])",
          "legendFormat": "{{task_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Requests aceptados vs bloqueados",
      "description": "Comparativa en el tiempo entre requests que pasaron el railguard y los bloqueados.",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(cubepath_route_requests_total[5m])",
          "legendFormat": "Aceptados",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(cubepath_route_blocked_total[5m])",
          "legendFormat": "Bloqueados",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Logs de Seguridad",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "logs",
      "title": "route.blocked_by_railguard — Detalle de bloqueos",
      "description": "Cada request bloqueado por el railguard. Incluye blockReason, taskType, requestId.",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=\"cubepath\"} | json | message = \"route.blocked_by_railguard\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "logs",
      "title": "route.validation_error — Errores de validación Zod",
      "description": "Requests rechazados por no pasar la validación del schema Zod. Incluye los errores de cada campo.",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 10 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=\"cubepath\"} | json | message = \"route.validation_error\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "logs",
      "title": "route.invalid_json — Body JSON malformado",
      "description": "Requests cuyo body no pudo parsearse como JSON válido.",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 10 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=\"cubepath\"} | json | message = \"route.invalid_json\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Todos los logs de nivel WARN y ERROR",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "logs",
      "title": "Logs WARN + ERROR — cubepath",
      "description": "Todos los logs de nivel warn o error del servicio. Útil para triaje de incidencias.",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 10 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=\"cubepath\"} | json | level =~ \"warn|error\"",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["cubepath", "security", "railguard"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values({service_name=\"cubepath\"}, deployment_environment)",
        "current": {},
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Cubepath — Security & Railguard",
  "uid": "cubepath-security",
  "version": 1
}
